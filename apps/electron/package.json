{
  "name": "doujinshi-manager",
  "version": "1.0.0",
  "description": "Local desktop manager for queued downloads and library organization",
  "author": "Full Swing",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:backend && electron .",
    "build:backend": "cd ../backend && set GOOS=windows&& set GOARCH=amd64&& go build -o doujinshi-manager.exe ./cmd/server",
    "build:verify-backend": "node verify-backend.js",
    "build": "npm run build:backend && npm run build:verify-backend && electron-builder --win",
    "package": "npm run build && npm --prefix ../browser-extension run build && node scripts/package-release.js",
    "dist": "npm run build",
    "pack:win": "npm run build"
  },
  "devDependencies": {
    "electron": "41.2.1",
    "electron-builder": "26.8.1",
    "electron-packager": "17.1.2"
  },
  "build": {
    "appId": "com.fullswing.manager",
    "productName": "Full Swing",
    "asar": true,
    "directories": {
      "output": "../../dist"
    },
    "files": [
      "*.js",
      "*.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/doujinshi-manager.exe",
        "to": "doujinshi-manager.exe"
      },
      {
        "from": "../../assets/icons",
        "to": "assets/icons"
      }
    ],
    "win": {
      "icon": "../../assets/icons/win/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Full Swing",
      "uninstallDisplayName": "Full Swing",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "../../assets/icons/win/icon.ico",
      "uninstallerIcon": "../../assets/icons/win/icon.ico",
      "installerHeaderIcon": "../../assets/icons/win/icon.ico"
    },
    "portable": {
      "artifactName": "Full-Swing-${version}-portable.exe"
    }
  }
}